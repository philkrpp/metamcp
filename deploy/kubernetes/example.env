METAMCP_NAMESPACE=metamcp
METAMCP_IMAGE=ghcr.io/metatool-ai/metamcp:latest
METAMCP_IMAGE_PULL_POLICY=Always

# Public URL used by browsers, OAuth callbacks, CORS, and MCP clients.
METAMCP_PUBLIC_URL=https://metamcp.example.com
METAMCP_HOST=metamcp.example.com

METAMCP_POSTGRES_DB=metamcp_db
METAMCP_POSTGRES_USER=metamcp_user
METAMCP_POSTGRES_PASSWORD=change-me
METAMCP_POSTGRES_STORAGE=10Gi
METAMCP_STORAGE_CLASS=standard

METAMCP_BETTER_AUTH_SECRET=change-me
METAMCP_BOOTSTRAP_USER_EMAIL=admin@example.com
METAMCP_BOOTSTRAP_USER_NAME=Admin
METAMCP_BOOTSTRAP_USER_PASSWORD=change-me

METAMCP_APP_CPU_REQUEST=500m
METAMCP_APP_MEMORY_REQUEST=1Gi
METAMCP_APP_CPU_LIMIT=2
METAMCP_APP_MEMORY_LIMIT=2Gi

METAMCP_POSTGRES_CPU_REQUEST=100m
METAMCP_POSTGRES_MEMORY_REQUEST=256Mi
METAMCP_POSTGRES_CPU_LIMIT=500m
METAMCP_POSTGRES_MEMORY_LIMIT=512Mi

# Generic ingress defaults. Update annotations for your ingress controller.
METAMCP_INGRESS_CLASS=nginx
METAMCP_TLS_SECRET=metamcp-tls
